{
  "name": "feimaotui-browser",
  "version": "1.3.0",
  "description": "飞毛腿浏览器 - 快速、安全、功能强大的浏览器",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish=never"
  },
  "build": {
    "appId": "com.electron.browser",
    "productName": "飞毛腿浏览器",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "build/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "飞毛腿浏览器",
      "artifactName": "Feimaotui-Browser-Setup-${version}.exe"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png"
    }
  },
  "keywords": [
    "browser",
    "electron",
    "video",
    "download",
    "translate"
  ],
  "author": "Electron Browser Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "cheerio": "^1.2.0",
    "makensis": "^3.0.5"
  }
}
